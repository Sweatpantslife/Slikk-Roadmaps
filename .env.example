# SQLite database (relative to prisma/ directory).
# Swap for a Postgres URL in production if you prefer — see README.
DATABASE_URL="file:./dev.db"

# Admin account created by `npm run db:seed`. Pick a strong password —
# this account can manage every post and publish the changelog.
# You can promote more accounts later with `npm run make-admin -- <email>`.
ADMIN_EMAIL="admin@slikk.app"
ADMIN_PASSWORD="change-me"
