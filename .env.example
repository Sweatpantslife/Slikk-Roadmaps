# ---------------------------------------------------------------------------
# Slikk Feedback Hub — environment
# Copy to .env for local dev. In Docker/Coolify these are set as service env
# vars (docker-compose.yml reads them), not from this file.
# ---------------------------------------------------------------------------

# --- Database (PostgreSQL) ---------------------------------------------------
# Local dev points at the dev database container
# (`docker compose -f docker-compose.dev.yml up -d`).
DATABASE_URL="postgresql://slikk:slikk@localhost:5432/slikk?schema=public"

# Used by docker-compose.yml to provision Postgres and build DATABASE_URL.
# On Coolify you can instead let it generate the password by referencing the
# magic SERVICE_PASSWORD_POSTGRES variable (already wired in the compose file).
POSTGRES_USER="slikk"
POSTGRES_PASSWORD="change-me-to-a-strong-password"
POSTGRES_DB="slikk"

# --- Admin account -----------------------------------------------------------
# Created on first boot and never overwritten. Pick a strong password — this
# account manages every post and publishes the changelog. Promote more accounts
# later with `npm run make-admin -- <email>`.
ADMIN_EMAIL="admin@slikk.app"
ADMIN_PASSWORD="change-me-to-a-strong-password"
# ADMIN_NAME="Slikk Team"

# --- Public URL (behind a TLS-terminating proxy) -----------------------------
# Coolify sets this from the service's domain automatically. For a plain
# `docker compose up` behind your own proxy, set it so Server Actions trust the
# forwarded host. ALLOWED_ORIGINS may list extra hostnames (comma-separated).
# APP_URL="https://feedback.example.com"
# ALLOWED_ORIGINS="feedback.example.com"

# --- Optional: release-notes HTTP API ----------------------------------------
# Enables POST /api/release-notes and /api/release-notes/ingest so a cron job
# or CI step can generate/submit release notes. Leave unset to keep disabled.
# RELEASE_NOTES_SECRET="a-long-random-string"
