generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// SQLite has no enums; string fields below hold the unions defined in lib/types.ts:
//   Post.category — "FEATURE" | "IMPROVEMENT" | "BUG"
//   Post.status   — "UNDER_REVIEW" | "PLANNED" | "IN_PROGRESS" | "SHIPPED" | "CLOSED"
//   ChangelogEntry.labels — comma-separated "NEW" | "IMPROVED" | "FIXED"
//   Notification.type — "STATUS_CHANGE" | "OFFICIAL_RESPONSE" | "NEW_COMMENT"

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  isAdmin      Boolean  @default(false)
  createdAt    DateTime @default(now())

  sessions      Session[]
  posts         Post[]
  comments      Comment[]
  votes         Vote[]
  subscriptions Subscription[]
  notifications Notification[]
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Post {
  id               String    @id @default(cuid())
  title            String
  body             String
  category         String    @default("FEATURE")
  appId            String?
  status           String    @default("UNDER_REVIEW")
  pinned           Boolean   @default(false)
  authorId         String
  officialResponse String?
  voteCount        Int       @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  shippedAt        DateTime?
  // Set when the shipped post is covered by release notes, so generation
  // includes each post exactly once. Deleting the entry re-queues the post.
  changelogEntryId String?

  author         User            @relation(fields: [authorId], references: [id], onDelete: Cascade)
  changelogEntry ChangelogEntry? @relation(fields: [changelogEntryId], references: [id], onDelete: SetNull)
  votes          Vote[]
  comments       Comment[]
  subscriptions  Subscription[]
  notifications  Notification[]

  @@index([status])
  @@index([category])
  @@index([changelogEntryId])
}

model Vote {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  authorId  String
  isTeam    Boolean  @default(false)
  body      String
  createdAt DateTime @default(now())

  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([postId])
}

model Subscription {
  id        String   @id @default(cuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  postId    String?
  type      String
  message   String
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post? @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
}

model ChangelogEntry {
  id          String   @id @default(cuid())
  title       String
  body        String
  labels      String   @default("NEW")
  appId       String?
  published   Boolean  @default(true)
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Shipped posts this entry covers (set by release-notes generation).
  posts Post[]

  @@index([published, publishedAt])
}
